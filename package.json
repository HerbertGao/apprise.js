{
  "name": "apprise.js",
  "version": "0.1.0",
  "description": "A faithful TypeScript translation of caronc/apprise — push notifications to many services via a single URL contract.",
  "type": "module",
  "sideEffects": false,
  "license": "BSD-2-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HerbertGao/apprise.js.git"
  },
  "homepage": "https://github.com/HerbertGao/apprise.js#readme",
  "bugs": "https://github.com/HerbertGao/apprise.js/issues",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "apprise",
    "notification",
    "notifications",
    "push",
    "discord",
    "slack",
    "telegram",
    "webhook"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugins/custom-json": {
      "import": {
        "types": "./dist/plugins/custom-json.d.ts",
        "default": "./dist/plugins/custom-json.js"
      },
      "require": {
        "types": "./dist/plugins/custom-json.d.cts",
        "default": "./dist/plugins/custom-json.cjs"
      }
    },
    "./plugins/custom-form": {
      "import": {
        "types": "./dist/plugins/custom-form.d.ts",
        "default": "./dist/plugins/custom-form.js"
      },
      "require": {
        "types": "./dist/plugins/custom-form.d.cts",
        "default": "./dist/plugins/custom-form.cjs"
      }
    },
    "./plugins/custom-xml": {
      "import": {
        "types": "./dist/plugins/custom-xml.d.ts",
        "default": "./dist/plugins/custom-xml.js"
      },
      "require": {
        "types": "./dist/plugins/custom-xml.d.cts",
        "default": "./dist/plugins/custom-xml.cjs"
      }
    },
    "./plugins/apprise-api": {
      "import": {
        "types": "./dist/plugins/apprise-api.d.ts",
        "default": "./dist/plugins/apprise-api.js"
      },
      "require": {
        "types": "./dist/plugins/apprise-api.d.cts",
        "default": "./dist/plugins/apprise-api.cjs"
      }
    },
    "./plugins/mattermost": {
      "import": {
        "types": "./dist/plugins/mattermost.d.ts",
        "default": "./dist/plugins/mattermost.js"
      },
      "require": {
        "types": "./dist/plugins/mattermost.d.cts",
        "default": "./dist/plugins/mattermost.cjs"
      }
    },
    "./plugins/discord": {
      "import": {
        "types": "./dist/plugins/discord.d.ts",
        "default": "./dist/plugins/discord.js"
      },
      "require": {
        "types": "./dist/plugins/discord.d.cts",
        "default": "./dist/plugins/discord.cjs"
      }
    },
    "./plugins/slack": {
      "import": {
        "types": "./dist/plugins/slack.d.ts",
        "default": "./dist/plugins/slack.js"
      },
      "require": {
        "types": "./dist/plugins/slack.d.cts",
        "default": "./dist/plugins/slack.cjs"
      }
    },
    "./plugins/telegram": {
      "import": {
        "types": "./dist/plugins/telegram.d.ts",
        "default": "./dist/plugins/telegram.js"
      },
      "require": {
        "types": "./dist/plugins/telegram.d.cts",
        "default": "./dist/plugins/telegram.cjs"
      }
    },
    "./plugins/rocketchat": {
      "import": {
        "types": "./dist/plugins/rocketchat.d.ts",
        "default": "./dist/plugins/rocketchat.js"
      },
      "require": {
        "types": "./dist/plugins/rocketchat.d.cts",
        "default": "./dist/plugins/rocketchat.cjs"
      }
    },
    "./plugins/matrix": {
      "import": {
        "types": "./dist/plugins/matrix.d.ts",
        "default": "./dist/plugins/matrix.js"
      },
      "require": {
        "types": "./dist/plugins/matrix.d.cts",
        "default": "./dist/plugins/matrix.cjs"
      }
    },
    "./plugins/all": {
      "import": {
        "types": "./dist/plugins/all.d.ts",
        "default": "./dist/plugins/all.js"
      },
      "require": {
        "types": "./dist/plugins/all.d.cts",
        "default": "./dist/plugins/all.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prepack": "pnpm run build",
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "markdown-it": "^14.3.0"
  }
}
