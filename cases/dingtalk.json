      "assertResult": true
    },
    {
      "name": "targets-path-and-query",
      "url": "dingtalk://abcdefgh/+86%20138-0013-8000/123/?to=13900139000,invalid",
      "title": "",
      "body": "targeted",
      "type": "warning",
      "assertResult": true
    },
    {
      "name": "signed",
      "url": "dingtalk://secret123@abcdefgh/13800138000/",
      "title": "Signed",
      "body": "deterministic",
      "assertResult": true,
      "seeds": { "timestampMs": 1700000000123 }
