      "assertResult": true
    },
    {
      "name": "cross-body-19986-truncate",
      "url": "feishu://abc123?format=text&overflow=truncate",
      "title": "",
      "body_gen": { "char": "x", "count": 19986 },
      "assertResult": true
    },
    {
